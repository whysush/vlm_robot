<?xml version="1.0"?>
<!-- Diff-drive base with a 2D lidar and an RGB-D camera. Sensor frame ids are
     overridden in the gazebo block to match these link names so the ros_gz
     bridge and Nav2/SLAM see consistent TF and sensor frames. -->
<robot name="robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="base_len"   value="0.70"/>
  <xacro:property name="base_wid"   value="0.45"/>
  <xacro:property name="base_hgt"   value="0.25"/>
  <xacro:property name="base_mass"  value="20.0"/>

  <xacro:property name="wheel_radius" value="0.10"/>
  <xacro:property name="wheel_width"  value="0.05"/>
  <xacro:property name="wheel_mass"   value="1.5"/>
  <xacro:property name="wheel_sep"    value="0.40"/>
  <xacro:property name="wheel_xoff"   value="-0.20"/>
  <xacro:property name="wheel_zoff"   value="0.0"/>

  <xacro:property name="caster_radius" value="0.05"/>
  <xacro:property name="caster_xoff"   value="0.28"/>

  <xacro:property name="lidar_xoff" value="0.25"/>
  <xacro:property name="lidar_zoff" value="0.20"/>

  <xacro:property name="cam_xoff" value="0.34"/>
  <xacro:property name="cam_zoff" value="0.15"/>

  <xacro:property name="PI" value="3.14159265359"/>

  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(y*y+z*z)/12.0}" ixy="0.0" ixz="0.0"
               iyy="${m*(x*x+z*z)/12.0}" iyz="0.0"
               izz="${m*(x*x+y*y)/12.0}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cyl_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(3*r*r+h*h)/12.0}" ixy="0.0" ixz="0.0"
               iyy="${m*(3*r*r+h*h)/12.0}" iyz="0.0"
               izz="${m*r*r/2.0}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="sphere_inertia" params="m r">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${2.0*m*r*r/5.0}" ixy="0.0" ixz="0.0"
               iyy="${2.0*m*r*r/5.0}" iyz="0.0"
               izz="${2.0*m*r*r/5.0}"/>
    </inertial>
  </xacro:macro>

  <!-- base_footprint is the ground-projected root for the odom->base chain. -->
  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="${base_len} ${base_wid} ${base_hgt}"/></geometry>
      <material name="robot_yellow"><color rgba="0.9 0.75 0.1 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="${base_len} ${base_wid} ${base_hgt}"/></geometry>
    </collision>
    <xacro:box_inertia m="${base_mass}" x="${base_len}" y="${base_wid}" z="${base_hgt}"/>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius + base_hgt/2.0}" rpy="0 0 0"/>
  </joint>

  <xacro:macro name="wheel" params="prefix yreflect">
    <link name="${prefix}_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="${PI/2.0} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="wheel_black"><color rgba="0.1 0.1 0.1 1.0"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${PI/2.0} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <xacro:cyl_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel"/>
      <origin xyz="${wheel_xoff} ${yreflect*wheel_sep/2.0} ${-base_hgt/2.0 + wheel_zoff}"
              rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel prefix="left"  yreflect="1"/>
  <xacro:wheel prefix="right" yreflect="-1"/>

  <link name="caster_wheel">
    <visual>
      <geometry><sphere radius="${caster_radius}"/></geometry>
      <material name="wheel_black"><color rgba="0.1 0.1 0.1 1.0"/></material>
    </visual>
    <collision>
      <geometry><sphere radius="${caster_radius}"/></geometry>
    </collision>
    <xacro:sphere_inertia m="0.5" r="${caster_radius}"/>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="${caster_xoff} 0 ${-base_hgt/2.0 - (wheel_radius - caster_radius)}"
            rpy="0 0 0"/>
  </joint>

  <link name="lidar_link">
    <visual>
      <geometry><cylinder radius="0.04" length="0.05"/></geometry>
      <material name="lidar_grey"><color rgba="0.2 0.2 0.2 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.04" length="0.05"/></geometry>
    </collision>
    <xacro:cyl_inertia m="0.2" r="0.04" h="0.05"/>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="${lidar_xoff} 0 ${base_hgt/2.0 + lidar_zoff}" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <geometry><box size="0.03 0.10 0.03"/></geometry>
      <material name="cam_blue"><color rgba="0.1 0.1 0.6 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.03 0.10 0.03"/></geometry>
    </collision>
    <xacro:box_inertia m="0.1" x="0.03" y="0.10" z="0.03"/>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="${cam_xoff} 0 ${base_hgt/2.0 + cam_zoff}" rpy="0 0 0"/>
  </joint>

  <!-- REP-103 camera optical frame (z forward, x right, y down). -->
  <link name="camera_optical_link"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_link"/>
    <origin xyz="0 0 0" rpy="${-PI/2.0} 0 ${-PI/2.0}"/>
  </joint>

  <xacro:include filename="$(find vlm_description)/urdf/robot.gazebo.xacro"/>

</robot>
